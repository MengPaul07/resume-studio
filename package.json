{
    "name":  "resume-studio",
    "private":  true,
    "version":  "0.1.0",
    "scripts":  {
                    "dev":  "concurrently -n backend,frontend -c yellow,cyan \"npm run dev:backend\" \"npm run dev:frontend\"",
                    "dev:backend":  "python -m uvicorn src.main:app --host 127.0.0.1 --port 8000 --reload",
                    "dev:frontend":  "npm --prefix frontend run dev",
                    "build":  "npm --prefix frontend run build",
                    "test":  "python -m pytest tests -q",
                    "test:frontend":  "npm --prefix frontend run build"
                },
    "devDependencies":  {
                            "concurrently":  "^9.0.1"
                        }
}
