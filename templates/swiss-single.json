{
  "template_id": "swiss-single",
  "display_name": "Swiss Single Column",
  "doc_type": "resume",
  "page": {
    "format": "a4",
    "margin": "18mm",
    "columns": 1
  },
  "type_scale": {
    "name":    { "size": 24, "weight": "bold",   "color": null,    "case": "none" },
    "title":   { "size": 14, "weight": "bold",   "color": null,    "case": "none" },
    "heading": { "size": 11, "weight": "bold",   "color": "muted", "case": "uppercase", "tracking": "wide" },
    "body":    { "size": 10, "weight": "normal", "color": null,    "case": "none" },
    "caption": { "size": 9,  "weight": "normal", "color": "muted", "case": "none" }
  },
  "sections": [
    {
      "key": "header",
      "title": null,
      "type": "single",
      "fields": [
        { "path": "personalInfo.name",     "tier": "name" },
        { "path": "personalInfo.title",    "tier": "body", "color": "muted" },
        { "path": "personalInfo.email",    "tier": "caption", "inline": true },
        { "path": "personalInfo.phone",    "tier": "caption", "inline": true },
        { "path": "personalInfo.location", "tier": "caption", "inline": true },
        { "path": "personalInfo.linkedin", "tier": "caption", "inline": true },
        { "path": "personalInfo.github",   "tier": "caption", "inline": true }
      ]
    },
    {
      "key": "summary",
      "title": "Summary",
      "type": "single",
      "fields": [
        { "path": "summary", "tier": "body" }
      ]
    },
    {
      "key": "workExperience",
      "title": "Experience",
      "type": "array",
      "item_spacing": "md",
      "item": {
        "fields": [
          { "path": "title",       "tier": "title" },
          { "path": "company",     "tier": "body", "inline": true },
          { "path": "years",       "tier": "caption", "inline": true, "color": "muted" },
          { "path": "description", "tier": "body", "bullet": true }
        ]
      }
    },
    {
      "key": "education",
      "title": "Education",
      "type": "array",
      "item_spacing": "md",
      "item": {
        "fields": [
          { "path": "institution", "tier": "title" },
          { "path": "degree",      "tier": "body" },
          { "path": "years",       "tier": "caption", "inline": true, "color": "muted" },
          { "path": "gpa",         "tier": "caption", "inline": true, "prefix": "GPA: " },
          { "path": "description", "tier": "body", "bullet": true }
        ]
      }
    },
    {
      "key": "personalProjects",
      "title": "Projects",
      "type": "array",
      "item_spacing": "md",
      "item": {
        "fields": [
          { "path": "name",        "tier": "title" },
          { "path": "role",        "tier": "body", "inline": true },
          { "path": "years",       "tier": "caption", "inline": true, "color": "muted" },
          { "path": "description", "tier": "body", "bullet": true }
        ]
      }
    },
    {
      "key": "research",
      "title": "Research",
      "type": "array",
      "item_spacing": "md",
      "item": {
        "fields": [
          { "path": "name",        "tier": "title" },
          { "path": "role",        "tier": "body", "inline": true },
          { "path": "institution", "tier": "caption", "inline": true, "color": "muted" },
          { "path": "years",       "tier": "caption", "inline": true, "color": "muted" },
          { "path": "description", "tier": "body", "bullet": true }
        ]
      }
    },
    {
      "key": "technicalSkills",
      "title": "Skills",
      "type": "key_value",
      "layout": "inline_tags",
      "fields": [
        { "path": "additional.technicalSkills", "tier": "caption", "bullet": true }
      ]
    },
    {
      "key": "languages",
      "title": "Languages",
      "type": "key_value",
      "layout": "list",
      "fields": [
        { "path": "additional.languages", "tier": "caption", "bullet": true }
      ]
    },
    {
      "key": "certifications",
      "title": "Certifications",
      "type": "key_value",
      "layout": "list",
      "fields": [
        { "path": "additional.certificationsTraining", "tier": "caption", "bullet": true }
      ]
    },
    {
      "key": "awards",
      "title": "Awards",
      "type": "key_value",
      "layout": "list",
      "fields": [
        { "path": "additional.awards", "tier": "caption", "bullet": true }
      ]
    }
  ]
}
