% !TEX program = xelatex
\documentclass[a4paper]{article}
\usepackage[hmargin={{ page_padding }}mm,vmargin={{ page_padding }}mm]{geometry}
\usepackage{fontspec}
\usepackage{xcolor}
\usepackage{enumitem}
\usepackage{hyperref}
\usepackage{ragged2e}
\usepackage[most]{tcolorbox}
\usepackage{xeCJK}

% -- fonts --
{% if has_chinese %}
\setmainfont{Noto Serif CJK SC}[Scale=MatchLowercase,Script=CJK]
\setCJKmainfont{Noto Serif CJK SC}[AutoFakeBold=2.5]
\newfontfamily\bodyfont{Noto Serif CJK SC}[Scale=MatchLowercase,Script=CJK]
\newfontfamily\headerfont{Noto Sans CJK SC}[Scale=MatchLowercase,Script=CJK,BoldFont=Noto Sans CJK SC Bold]
{% else %}
\setmainfont{ {{ body_font_name }} }[Scale=MatchLowercase]
\newfontfamily\bodyfont{ {{ body_font_name }} }[Scale=MatchLowercase]
\newfontfamily\headerfont{ {{ header_font_name }} }[Scale=MatchLowercase]
{% endif %}

% -- colors --
\definecolor{accent}{HTML}{ {{ accent }} }
\definecolor{accentmuted}{HTML}{ {{ accent_muted }} }
\definecolor{body}{HTML}{ {{ body_color }} }
\definecolor{meta}{HTML}{ {{ meta_color }} }
\definecolor{headerbg}{HTML}{ {{ header_bg }} }
\definecolor{headertext}{HTML}{ {{ header_text }} }
\definecolor{sidebarbg}{HTML}{ {{ sidebar_bg }} }
\definecolor{divider}{HTML}{ {{ divider_color }} }
\definecolor{tagbg}{HTML}{ {{ tag_bg }} }
\definecolor{tagborder}{HTML}{ {{ tag_border }} }

% -- page --
\pagecolor{white}
\color{body}
\bodyfont
\setlength{\parindent}{0pt}
\setlength{\parskip}{0pt}
\pagestyle{empty}

% -- macros --
{{ cvsection_def }}

{{ cvtag_def }}

{{ expheader_def }}

\begin{document}

% ========== HEADER ==========
{% if header_layout == "center" %}
\begin{center}
  {\headerfont\fontsize{ {{ name_size }} }{ {{ name_leading }} }\selectfont\bfseries {{ name }} }
  {% if role %}
  \par\vspace{ {{ role_mt }} pt}
  {\fontsize{ {{ role_size }} }{ {{ role_leading }} }\selectfont\color{headertext!70} {{ role }} }
  {% endif %}
  {% if contacts or links %}
  \par\vspace{ {{ contact_gap }} pt}
  {\fontsize{ {{ meta_size }} }{ {{ meta_leading }} }\selectfont\color{meta}
    {% for c in contacts %}{{ c }}{% if not loop.last %} \,\textbullet\, {% endif %}{% endfor %}
    {% if links %}\\{% for l in links %}{{ l }}{% if not loop.last %} \,\textbullet\, {% endif %}{% endfor %}{% endif %}
  }
  {% endif %}
\end{center}

{% elif header_layout == "split" %}
\noindent
\begin{minipage}[t]{0.55\textwidth}
  \RaggedRight
  {\headerfont\fontsize{ {{ name_size }} }{ {{ name_leading }} }\selectfont\bfseries {{ name }} }
  {% if role %}
  \par\vspace{ {{ role_mt }} pt}
  {\fontsize{ {{ role_size }} }{ {{ role_leading }} }\selectfont\color{headertext!70} {{ role }} }
  {% endif %}
\end{minipage}
\hfill
\begin{minipage}[t]{0.4\textwidth}
  \RaggedLeft
  {\fontsize{ {{ meta_size }} }{ {{ meta_leading }} }\selectfont\color{meta}
    {% for c in contacts %}{{ c }}\par{% endfor %}
    {% for l in links %}{{ l }}\par{% endfor %}
  }
\end{minipage}

{% else %}
\noindent{\RaggedRight
  {\headerfont\fontsize{ {{ name_size }} }{ {{ name_leading }} }\selectfont\bfseries {{ name }} }
  {% if role %}
  \par\vspace{ {{ role_mt }} pt}
  {\fontsize{ {{ role_size }} }{ {{ role_leading }} }\selectfont\color{headertext!70} {{ role }} }
  {% endif %}
  {% if contacts or links %}
  \par\vspace{ {{ contact_gap }} pt}
  {% if contact_layout == "inline" %}
  {\fontsize{ {{ meta_size }} }{ {{ meta_leading }} }\selectfont\color{meta}
    {% for c in contacts %}{{ c }}{% if not loop.last %} \,\textbullet\, {% endif %}{% endfor %}
    {% if links %}\par\vspace{2pt}{% for l in links %}{{ l }}{% if not loop.last %} \,\textbullet\, {% endif %}{% endfor %}{% endif %}
  }
  {% else %}
  {\fontsize{ {{ meta_size }} }{ {{ meta_leading }} }\selectfont\color{meta}
    {% for c in contacts %}{{ c }}\par{% endfor %}
    {% for l in links %}{{ l }}\par{% endfor %}
  }
  {% endif %}
  {% endif %}
  \par}
{% endif %}

\vspace{ {{ header_pad }} pt}
{% if show_divider %}
\noindent\textcolor{divider}{\rule{\linewidth}{ {{ divider_thick }} pt}}\par
{% endif %}
\vspace{ {{ header_margin }} pt}

% ========== BODY ==========
{% if is_double and left_sections %}
\noindent
\colorbox{sidebarbg}{
\begin{minipage}[t]{ {{ left_col_width }} }
\vspace{ {{ sidebar_padding }} pt}
\hspace{ {{ sidebar_padding }} pt}\begin{minipage}[t]{\dimexpr\linewidth - {{ sidebar_inner_deduct }}pt\relax}
\RaggedRight
{% for sec in left_sections %}{% include "section.tex.jinja2" %}{% endfor %}
\end{minipage}
\vspace{ {{ sidebar_padding }} pt}
\end{minipage}
}
\hfill
\begin{minipage}[t]{ {{ right_col_width }} }
\RaggedRight
{% for sec in right_sections %}{% include "section.tex.jinja2" %}{% endfor %}
\end{minipage}
{% else %}
{% for sec in left_sections %}{% include "section.tex.jinja2" %}{% endfor %}
{% for sec in right_sections %}{% include "section.tex.jinja2" %}{% endfor %}
{% endif %}

\end{document}
