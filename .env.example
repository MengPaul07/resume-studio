# Copy to .env and fill with your real keys
API_KEY=
API_BASE=https://api.deepseek.com

# Model (deepseek-chat / gpt-4o / claude-sonnet-4-6 / ...)
LLM_MODEL=deepseek-chat

# Production CORS origins (comma-separated)
# Local: http://localhost:5173,http://localhost:8000
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Upload directory (local path or volume mount)
UPLOAD_DIR=./uploads

# RAG (JD search) — set to true to enable FAISS indexing
RAG_ENABLED=false

# Debug mode
DEBUG=false

# Frontend API base (set in Vercel env, not .env)
# VITE_API_BASE=https://your-railway-app.up.railway.app/api/v1
